# TechPulse AI 环境变量
# 复制为 .env 并填入实际值后启动

# 阿里云访问凭证
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_ak_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_ak_secret

# 阿里云 MaxCompute 配置
MAXCOMPUTE_PROJECT=techpulse_dw
MAXCOMPUTE_ENDPOINT=http://service.cn-hongkong.maxcompute.aliyun.com/api

# 阿里云 DashScope (灵积) API Key
DASHSCOPE_KEY=your_dashscope_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key
