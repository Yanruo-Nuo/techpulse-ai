{
  "uid": "techpulse-monitoring",
  "title": "TechPulse AI Monitoring",
  "tags": ["techpulse"],
  "schemaVersion": 36,
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "title": "服务健康",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Consumer 存活",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "Consumer 进程是否在运行。1=正常，0=已停止",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "targets": [
        { "expr": "consumer_alive{job=\"consumer-health\"}", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "运行状态",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "value": "1", "text": "✅ 运行中" },
            { "type": "value", "value": "0", "text": "❌ 已停止" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "管线阶段",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "当前管线所处阶段：空闲 / 抓取中 / AI 处理中 / 写入中",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "targets": [
        { "expr": "consumer_pipeline_stage{job=\"consumer-health\"}", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "当前阶段",
          "color": { "mode": "none" },
          "mappings": [
            { "type": "value", "value": "0", "text": "⏸ 空闲" },
            { "type": "value", "value": "1", "text": "🌐 抓取中" },
            { "type": "value", "value": "2", "text": "🤖 AI 处理中" },
            { "type": "value", "value": "3", "text": "💾 写入中" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "上次成功写入",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "距离上次成功写入 OSS 已过去的时间。超过30分钟表示管线异常",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "targets": [
        { "expr": "(time() - consumer_last_success_timestamp{job=\"consumer-health\"}) and (consumer_last_success_timestamp{job=\"consumer-health\"} > 0)", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "displayName": "距上次成功",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 600 },
              { "color": "red", "value": 3600 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "special", "match": "null", "text": "❌ 从未成功" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "待处理消息",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "Consumer 缓冲区中待处理的文章数。持续堆积表示处理速度落后于采集速度",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "targets": [
        { "expr": "consumer_pending_articles{job=\"consumer-health\"}", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "待处理数",
          "color": { "mode": "none" },
          "mappings": [
            { "type": "special", "match": "null", "text": "0" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "Kafka 消费积压",
      "type": "timeseries",
      "datasource": "Prometheus",
      "description": "Kafka 分区积压量（未消费消息数）。持续增长表示 consumer 处理速度不够",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "expr": "kafka_consume_lag{job=\"consumer-health\"}", "legendFormat": "partition 0" }
      ]
    },
    {
      "title": "AI Token 消耗趋势",
      "type": "timeseries",
      "datasource": "Prometheus",
      "description": "DashScope LLM 的 Token 消耗速率。异常飙升可能表示管线循环",
      "gridPos": { "h": 12, "w": 8, "x": 0, "y": 7 },
      "targets": [
        { "expr": "rate(ai_token_usage_total{job=\"orchestrator\"}[5m]) or vector(0)", "legendFormat": "{{model}} {{operation}}" }
      ]
    },
    {
      "title": "爬虫采集延迟",
      "type": "timeseries",
      "datasource": "Prometheus",
      "description": "各来源爬虫的采集延迟（秒）。值越大表示该源爬虫越久未成功采集",
      "gridPos": { "h": 12, "w": 8, "x": 8, "y": 7 },
      "targets": [
        { "expr": "crawler_produce_lag_seconds{job=\"news-crawler\"}", "legendFormat": "{{source}}" }
      ]
    },
    {
      "title": "管线指标",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }
    },
    {
      "title": "OSS 写入状态",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "最近 1 小时 OSS 成功写入的文章数。0 表示无写入",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 20 },
      "targets": [
        { "expr": "increase(oss_write_total{job=\"orchestrator\",status='success'}[1h])", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "1h 写入量",
          "color": { "mode": "none" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "MaxCompute 同步",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "OSS→MaxCompute 同步状态。绿色=最近成功，红=失败/未运行",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 20 },
      "targets": [
        { "expr": "mc_sync_success{job=\"orchestrator-sync\"}", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "同步结果",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "value": "0", "text": "⏸ 未运行" },
            { "type": "value", "value": "1", "text": "✅ 同步成功" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "dbt 运行状态",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "dbt 转换作业状态。绿色=成功，红色=失败，灰色=未运行",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 20 },
      "targets": [
        { "expr": "dbt_run_success{job=\"orchestrator-sync\"}", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "dbt 结果",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "value": "0", "text": "⏸ 未运行" },
            { "type": "value", "value": "1", "text": "✅ 执行成功" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "429 限流计数",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "DashScope API 返回 429 的次数。非零表示触发了限流，需要降低请求频率",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 20 },
      "targets": [
        { "expr": "increase(ai_rate_limit_hits_total{job=\"orchestrator\"}[1h])", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "displayName": "1h 限流数",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "value": "0", "text": "✅ 无限流" },
            { "type": "special", "match": "null", "text": "0" }
          ]
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "MaxCompute 扫描量",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "MaxCompute 数据扫描量",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 20 },
      "targets": [
        { "expr": "increase(mc_query_scanned_bytes_total[1h])", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "displayName": "1h 扫描量",
          "color": { "mode": "none" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "dbt 运行时长",
      "type": "stat",
      "datasource": "Prometheus",
      "description": "dbt 作业最近一次运行耗时",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 20 },
      "targets": [
        { "expr": "dbt_run_duration_seconds", "legendFormat": "__auto" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "displayName": "运行时长",
          "color": { "mode": "none" }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "title": "AI 字段缺失率",
      "type": "timeseries",
      "datasource": "Prometheus",
      "description": "AI 字段缺失率（摘要、分类）与 Others 兜底分类占比。超出阈值需排查",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "expr": "dq_ai_summary_missing_ratio{job=\"tech-frontend\"}", "legendFormat": "摘要缺失率" },
        { "expr": "dq_ai_category_missing_ratio{job=\"tech-frontend\"}", "legendFormat": "分类缺失率" },
        { "expr": "dq_others_category_ratio{job=\"tech-frontend\"}", "legendFormat": "Others 占比" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.4 }
            ]
          }
        }
      }
    }
  ]
}
